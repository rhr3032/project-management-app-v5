generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notifications Notification[]
}

model Project {
  id             String   @id @default(cuid())
  name           String
  description    String   @default("")
  type           String
  projectType    String   @default("")
  status         String
  priority       String
  effort         String
  device         String   @default("")
  creatorName    String   @map("owner")
  industry       String   @default("")
  startDate      String   @default("")
  endDate        String   @default("")
  deadline       String   @default("")
  clientName     String   @default("")
  clientEmail    String   @default("")
  clientPhone    String   @default("")
  clientAddress  String   @default("")
  previewLink    String   @default("")
  resourceLinks  Json     @default("[]")
  shortOverview  String   @default("")
  businessGoal   String   @default("")
  targetAudience String   @default("")
  competitors    String   @default("")
  tags           Json     @default("[]")
  techStack      Json     @default("[]")
  toolsUsed      Json     @default("[]")
  company        String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  notifications  Notification[]
  statusLogs     ProjectStatusLog[]
}

model Notification {
  id          String   @id @default(cuid())
  uniqueKey   String   @unique
  userId      String
  projectId   String
  projectName String
  kind        String
  tone        String
  title       String
  description String
  href        String
  isRead      Boolean  @default(false)
  isActive    Boolean  @default(true)
  readAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectStatusLog {
  id         String   @id @default(cuid())
  projectId  String
  fromStatus String   @default("")
  toStatus   String
  changedAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TechOption {
  id   String @id @default(cuid())
  name String @unique
}

model ToolOption {
  id   String @id @default(cuid())
  name String @unique
}

