# Database Connection
# Add your Neon PostgreSQL connection string here when ready
# Get it from: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Example format for local development:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/project_hub

# API Configuration
# Leave these as defaults for local development
NEXT_PUBLIC_API_URL=http://localhost:3000

# Environment
NODE_ENV=development
